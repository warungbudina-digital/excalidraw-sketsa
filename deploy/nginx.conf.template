# nginx site config for the production app container.
#
# This file is a *template*: the nginx:alpine image runs `envsubst` over every
# /etc/nginx/templates/*.template at startup, so `${OLLAMA_HOST}` below is filled in
# from the container env. NGINX_ENVSUBST_FILTER (set in the Dockerfile) limits substitution
# to our OLLAMA_* and COLLAB_* vars, so nginx's own $uri/$host/$1 stay intact.

server {
    listen       80;
    server_name  _;

    root   /usr/share/nginx/html;
    index  index.html;

    # Docker's embedded DNS. Using it (plus a variable in proxy_pass below) makes the
    # ollama upstream resolve at request time, so the ollama container can be recreated
    # with a new IP without having to restart nginx.
    resolver 127.0.0.11 ipv6=off valid=10s;

    # Long-cache the content-hashed Vite build assets; never cache the HTML shell.
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # SPA fallback: any unknown path serves index.html so client routing works.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Live collaboration: SSE events + scene update POSTs. Buffering must stay disabled or
    # presence/scene events would be delayed until nginx accumulates a response buffer.
    location /collab/ {
        set $collab_upstream ${COLLAB_HOST};
        rewrite ^/collab/(.*)$ /$1 break;
        proxy_pass http://$collab_upstream;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
        proxy_send_timeout 60s;
        client_max_body_size 15m;
    }

    # Reverse proxy to the *private* Ollama container — the production mirror of the
    # Vite dev proxy in vite.config.ts. The browser calls same-origin /ollama/* so there
    # is no CORS, and Ollama is never published to the host/internet.
    #
    # Origin/Referer are stripped because Ollama (0.x) returns HTTP 403 for browser
    # requests whose Origin isn't localhost; clearing them makes Ollama treat the proxied
    # call as a non-browser client (same fix as the dev proxy).
    location /ollama/ {
        set $ollama_upstream ${OLLAMA_HOST};
        rewrite ^/ollama/(.*)$ /$1 break;
        proxy_pass http://$ollama_upstream;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Origin "";
        proxy_set_header Referer "";

        # Model generation can be slow on small hardware; don't cut it off, and stream
        # the response straight through instead of buffering the whole body.
        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    # Reverse proxy to the Claude AI backend (same dialect as /ollama/, parallel route).
    # Browser picks /claude/ when the user selects "Claude" in the Script panel toggle.
    location /claude/ {
        set $claude_upstream ${CLAUDE_HOST};
        rewrite ^/claude/(.*)$ /$1 break;
        proxy_pass http://$claude_upstream;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Origin "";
        proxy_set_header Referer "";

        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    # Reverse proxy to the Antigravity CLI (agy) backend — third parallel route.
    # Browser picks /agy/ when the user selects "Antigravity" in the Script panel toggle.
    location /agy/ {
        set $agy_upstream ${AGY_HOST};
        rewrite ^/agy/(.*)$ /$1 break;
        proxy_pass http://$agy_upstream;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Origin "";
        proxy_set_header Referer "";

        proxy_buffering off;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }
}
