{
  "name": "excalidraw-sketsa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone Excalidraw web app reusing the core save/load/compress + scripting logic of the obsidian-excalidraw-plugin.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:scene-code": "esbuild tests/scene-code.test.ts --bundle --platform=node --format=esm --outfile=/tmp/scene-code.test.mjs && node /tmp/scene-code.test.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "2.2.2",
    "lz-string": "1.5.0",
    "nanoid": "5.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
