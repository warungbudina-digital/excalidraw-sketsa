{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|WebFetch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/nudge claude hook",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/nudge claude hook",
            "timeout": 5
          }
        ]
      }
    ]
  }
}