# Copy to .env and fill in. .env is gitignored (never commit secrets).
#   cp .env.example .env

# --- Cloudflare Zero Trust tunnel (REQUIRED for the cloudflared service) ---------------
# Create a tunnel in the Zero Trust dashboard (Networks -> Tunnels -> Create a tunnel,
# choose "Cloudflared"), then copy the connector token it shows. In the tunnel's
# "Public hostname" tab, route your hostname to the service: http://app:80
CLOUDFLARE_TUNNEL_TOKEN=

# --- AI backend (pick ONE) -------------------------------------------------------------
# local = on-VPS Ollama (private, free, heavier). cloud = OpenAI gpt-5-mini via ai-proxy
# (light VPS, strong instruction-following, needs an API key; prompts go to OpenAI).
# COMPOSE_PROFILES decides which backend service runs; AI_UPSTREAM points the app at it.
#   local:  COMPOSE_PROFILES=local   AI_UPSTREAM=ollama:11434
#   cloud:  COMPOSE_PROFILES=cloud   AI_UPSTREAM=ai-proxy:8080
COMPOSE_PROFILES=local
AI_UPSTREAM=ollama:11434

# Required ONLY for the cloud backend (COMPOSE_PROFILES=cloud). Server-side only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Reasoning effort (gpt-5-mini & codex-mini are reasoning models): low (fast/cheap) | medium |
# high. gpt-5-mini also accepts "minimal" for the fastest/cheapest runs.
OPENAI_REASONING_EFFORT=low

# --- Optional overrides ----------------------------------------------------------------
# Custom Ollama model name; baked into the app bundle AND built by the ollama service.
VITE_OLLAMA_MODEL=excalidraw-ea

# Host port for the app (container always listens on 80). Avoid Cloud Shell's reserved
# ports (22, 900, 922, 970, 971, 980, 981, 8998).
APP_PORT=8080

# Where Ollama stores models on the host (kept out of the ephemeral docker volume).
# OLLAMA_DATA=/home/youruser/ollama-data

# Timezone for container logs.
TZ=Asia/Makassar
