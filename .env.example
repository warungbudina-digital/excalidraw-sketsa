# Copy to .env and fill in. .env is gitignored (never commit secrets).
#   cp .env.example .env

# --- Cloudflare Zero Trust tunnel (REQUIRED for the cloudflared service) ---------------
# Create a tunnel in the Zero Trust dashboard (Networks -> Tunnels -> Create a tunnel,
# choose "Cloudflared"), then copy the connector token it shows. In the tunnel's
# "Public hostname" tab, route your hostname to the service: http://app:80
CLOUDFLARE_TUNNEL_TOKEN=

# --- AI backend: Codex CLI (ChatGPT subscription) --------------------------------------
# The `codex` service runs by default. After first `docker compose up -d`, log in ONCE
# so the credential persists to the codex-auth volume:
#   docker compose exec codex codex login --device-auth
# Then the Script panel's AI generation (Codex backend) works. See docs/adr/0001.

# Optional model override. EMPTY = the model your subscription grants (Codex default).
CODEX_MODEL=
# How many times the shim re-prompts Codex if the generated script fails validation.
CODEX_MAX_ATTEMPTS=2
# (Codex auth persists in the `codex-auth` named volume — no host path to configure.)

# Optional: point the app at a different AI upstream (host:port speaking the Ollama dialect).
# AI_UPSTREAM=codex:8082

# --- AI backend: Claude Code CLI (Claude subscription) ---------------------------------
# The `claude` service is the second backend; users switch in the Script panel UI.
# Uses the Claude Code CLI (`claude --print`) on your Claude subscription — parallel to
# how the codex service uses the Codex CLI on your ChatGPT subscription.
# After first `docker compose up -d`, log in ONCE so credentials persist to claude-auth volume:
#   docker compose exec claude claude auth login
# (credentials live in the `claude-auth` named volume at HOME=/claude-home)

# Optional model override. EMPTY = the model your Claude subscription grants.
CLAUDE_MODEL=
# How many times the shim re-prompts Claude if the generated script fails validation.
CLAUDE_MAX_ATTEMPTS=2

# --- AI backend: Antigravity CLI (Google subscription) ---------------------------------
# The `agy` service is the third backend; users switch in the Script panel UI.
# Uses the Antigravity CLI (`agy --print`) on your Google account — parallel to
# how codex uses the Codex CLI on ChatGPT and claude uses Claude Code CLI.
# Auth ONCE (credentials persist to the `agy-auth` named volume at HOME=/agy-home):
#   docker compose exec agy agy
#   (follow the Google OAuth URL it prints to sign in — no dedicated `auth` subcommand)
# (credentials live in the `agy-auth` named volume at HOME=/agy-home/.config/antigravity)

# Optional model override. EMPTY = the model your Google subscription grants.
AGY_MODEL=
# How many times the shim re-prompts agy if the generated script fails validation.
AGY_MAX_ATTEMPTS=2

# --- AI memory backend (Supabase) ------------------------------------------------------
# The `memory` service captures each AI generation turn (prompt + response + scene) to
# Supabase (Postgres via PostgREST). Private — reached only by nginx (/memory/*). Optional:
# leave SUPABASE_* empty and capture is simply disabled (the container still boots).
# Setup: run deploy/memory/schema.sql in the Supabase SQL Editor, then fill these in.
#   SUPABASE_URL    = base project URL ONLY (server.js appends /rest/v1/), e.g.
#                     https://YOUR-PROJECT.supabase.co   — NOT the full /rest/v1/ endpoint
#   SUPABASE_SERVICE_KEY = service/secret key (server-side only; never reaches the browser)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Keep-alive ping cadence (ms). Default 3 days — under Supabase's ~7-day idle auto-pause.
MEMORY_PING_INTERVAL_MS=259200000

# --- Optional overrides ----------------------------------------------------------------
# Host port for the app (container always listens on 80). Avoid Cloud Shell's reserved
# ports (22, 900, 922, 970, 971, 980, 981, 8998).
APP_PORT=8080

# --- Optional: horizontal scaling for live collaboration -------------------------------
# By default `collab` runs single-instance (in-memory) — leave these unset to keep that.
# To run MULTIPLE collab replicas behind nginx, enable the Redis backplane: add `scale` to
# COMPOSE_PROFILES, set REDIS_URL, then start with `--scale collab=2`. See docs/SCALING.md.
#   COMPOSE_PROFILES=scale
#   REDIS_URL=redis://redis:6379

# Timezone for container logs.
TZ=Asia/Makassar
